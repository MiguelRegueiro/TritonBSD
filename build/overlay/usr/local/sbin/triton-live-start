#!/bin/sh

PATH=/sbin:/bin:/usr/sbin:/usr/bin:/usr/local/sbin:/usr/local/bin
export PATH

LOG="${TRITON_LIVE_LOG:-/tmp/triton-live.log}"

if [ "$(id -u)" -eq 0 ]; then
    touch "$LOG"
    chown triton:triton "$LOG" 2>/dev/null || true
    chmod 664 "$LOG" 2>/dev/null || true

    {
        echo "==== Triton live startup as root $(date) ===="
        uname -a
        id triton || true
        echo "Starting required services"
    } >> "$LOG" 2>&1

    mkdir -p \
        /tmp/triton-home \
        /tmp/triton-runtime \
        /tmp/triton-cache/hyprland \
        /tmp/triton-state \
        /tmp/triton-data

    if ! mount | grep -q ' on /home/triton '; then
        echo "Preparing writable live home" >> "$LOG"
        tar -C /home/triton -cf - . 2>> "$LOG" | tar -C /tmp/triton-home -xpf - 2>> "$LOG" || true
        chown -R triton:triton /tmp/triton-home 2>/dev/null || true
        mount_nullfs /tmp/triton-home /home/triton >> "$LOG" 2>&1 || \
            echo "Warning: failed to mount writable /home/triton" >> "$LOG"
    fi

    chown -R triton:triton \
        /tmp/triton-home \
        /tmp/triton-runtime \
        /tmp/triton-cache \
        /tmp/triton-state \
        /tmp/triton-data 2>/dev/null || true
    chmod 700 \
        /tmp/triton-home \
        /tmp/triton-runtime \
        /tmp/triton-cache \
        /tmp/triton-cache/hyprland \
        /tmp/triton-state \
        /tmp/triton-data 2>/dev/null || true

    service dbus onestart >> "$LOG" 2>&1 || true
    service seatd onestart >> "$LOG" 2>&1 || true

    if [ -x /usr/local/sbin/triton-gpu-preflight ]; then
        /usr/local/sbin/triton-gpu-preflight --load >> "$LOG" 2>&1 || true
    fi

    exec su -l triton -c /usr/local/sbin/triton-live-start
fi

LIVE_USER="$(id -un 2>/dev/null || echo triton)"
LIVE_HOME="/home/$LIVE_USER"
if [ "$LIVE_USER" = "triton" ]; then
    LIVE_HOME=/home/triton
fi

export HOME="${HOME:-$LIVE_HOME}"
case "$HOME" in
    ""|/) export HOME="$LIVE_HOME" ;;
esac
export USER="${USER:-$LIVE_USER}"
export LOGNAME="${LOGNAME:-$LIVE_USER}"
export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-/tmp/triton-cache}"
export XDG_DATA_HOME="${XDG_DATA_HOME:-/tmp/triton-data}"
export XDG_STATE_HOME="${XDG_STATE_HOME:-/tmp/triton-state}"

mkdir -p \
    "$XDG_CONFIG_HOME" \
    "$XDG_CACHE_HOME" \
    "$XDG_DATA_HOME" \
    "$XDG_STATE_HOME" 2>/dev/null || true

if [ ! -w "$LOG" ]; then
    LOG="/tmp/triton-live-$(id -un).log"
    touch "$LOG" 2>/dev/null || LOG="/dev/null"
fi

clear
{
    echo "==== Triton live user session $(date) ===="
    uname -a
    id
    tty || true
    echo
} >> "$LOG" 2>&1

echo "Starting Triton live desktop..."
echo "Log: $LOG"
echo

if [ -x /home/triton/.start-hyprland ]; then
    /home/triton/.start-hyprland >> "$LOG" 2>&1
    status=$?
    echo
    echo "Triton desktop exited with status $status."
    echo "Last log lines:"
    tail -40 "$LOG"
    echo
    echo "Hyprland cache logs:"
    find /tmp/triton-cache/hyprland /home/triton/.cache/hyprland -type f 2>/dev/null | sort | tail -5 | while read -r file; do
        echo "---- $file ----"
        tail -40 "$file"
    done
else
    echo "Missing /home/triton/.start-hyprland"
    echo "Missing /home/triton/.start-hyprland" >> "$LOG"
fi

echo
echo "You are in the TritonBSD live shell."
echo "Run triton-install to start the installer."
if command -v fish >/dev/null 2>&1; then
    export HOME=/home/triton
    export USER=triton
    export LOGNAME=triton
    export XDG_CONFIG_HOME=/home/triton/.config
    export XDG_CACHE_HOME=/tmp/triton-cache
    export XDG_DATA_HOME=/tmp/triton-data
    export XDG_STATE_HOME=/tmp/triton-state
    mkdir -p \
        "$XDG_CONFIG_HOME/fish" \
        "$XDG_CACHE_HOME/fish" \
        "$XDG_DATA_HOME/fish" \
        "$XDG_STATE_HOME/fish" 2>/dev/null || true
    exec fish -l
fi
exec /bin/sh -i
