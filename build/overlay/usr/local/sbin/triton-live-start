#!/bin/sh

PATH=/sbin:/bin:/usr/sbin:/usr/bin:/usr/local/sbin:/usr/local/bin
export PATH

LOG="${TRITON_LIVE_LOG:-/tmp/triton-live.log}"

if [ "$(id -u)" -eq 0 ]; then
    {
        echo "==== Triton live startup as root $(date) ===="
        uname -a
        id triton || true
        echo "Starting required services"
    } >> "$LOG" 2>&1

    mkdir -p /tmp/triton-runtime
    chown triton:triton /tmp/triton-runtime 2>/dev/null || true
    chmod 700 /tmp/triton-runtime 2>/dev/null || true

    service dbus onestart >> "$LOG" 2>&1 || true
    service seatd onestart >> "$LOG" 2>&1 || true

    exec su -l triton -c /usr/local/sbin/triton-live-start
fi

clear
{
    echo "==== Triton live user session $(date) ===="
    uname -a
    id
    tty || true
    echo
} >> "$LOG" 2>&1

echo "Starting Triton live desktop..."
echo "Log: $LOG"
echo

if [ -x /home/triton/.start-hyprland ]; then
    /home/triton/.start-hyprland >> "$LOG" 2>&1
    status=$?
    echo
    echo "Triton desktop exited with status $status."
    echo "Last log lines:"
    tail -40 "$LOG"
else
    echo "Missing /home/triton/.start-hyprland"
    echo "Missing /home/triton/.start-hyprland" >> "$LOG"
fi

echo
echo "You are in the TritonBSD live shell."
echo "Run triton-install to start the installer."
exec /bin/sh -i
